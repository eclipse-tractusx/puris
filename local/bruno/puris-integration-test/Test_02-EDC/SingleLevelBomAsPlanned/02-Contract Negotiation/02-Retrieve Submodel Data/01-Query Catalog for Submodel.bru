meta {
  name: 01-Query Catalog for Submodel
  type: http
  seq: 1
  tags: [
    exchange-anonymized-data
  ]
}

post {
  url: {{SUPPLIER_EDC}}/{{MANAGEMENT_PATH}}/v3/catalog/request
  body: json
  auth: apikey
}

auth:apikey {
  key: X-API-KEY
  value: {{SUPPLIER_EDC_API_KEY}}
  placement: header
}

body:json {
  {
    "@context": {
      "@vocab": "https://w3id.org/edc/v0.0.1/ns/"
    },
    "@type": "CatalogRequest",
    "protocol": "dataspace-protocol-http",
    "counterPartyAddress": "{{SUPPLIER_EDC_EXT_HOSTNAME}}/{{PROTOCOL_PATH}}",
    "counterPartyId": "{{SUPPLIER_BPNL}}",
    "querySpec": {
      "offset": 0,
      "limit": 100,
      "filter": "",
      "range": {
        "from": 0,
        "to": 100
      },
      "filterExpression": [
        {
          "@type": "CriterionDto",
          "operandLeft": "https://w3id.org/catenax/ontology/common#version",
          "operator": "=",
          "operandRight": "3.0"
        },
        {
          "@type": "CriterionDto",
          "operandLeft": "'http://purl.org/dc/terms/type'.'@id'",
          "operator": "=",
          "operandRight": "https://w3id.org/catenax/taxonomy#Submodel"
        }
      ]
    }
  }
}

script:post-response {
  const jsonData = res.getBody();
  const semanticId = "urn:samm:io.catenax.single_level_bom_as_planned:3.0.0#SingleLevelBomAsPlanned";

  const datasets = jsonData['dcat:dataset'];
  const catalog = Array.isArray(datasets) ? datasets : [datasets];

  const catalogEntry = catalog.find(ce =>
    ce["https://admin-shell.io/aas/3/0/HasSemantics/semanticId"]?.["@id"] === semanticId
  );
  if (!catalogEntry) throw new Error("No catalog entry found for semanticId: " + semanticId);

  const rawOffer = catalogEntry["odrl:hasPolicy"];
  const offer = Array.isArray(rawOffer) ? rawOffer[0] : rawOffer;
  if (!offer) throw new Error("No odrl:hasPolicy found in catalog entry");

  const offerId = offer["@id"];
  const assetId = catalogEntry["@id"] || catalogEntry.id;
  if (!offerId || !assetId) throw new Error("Missing offerId or assetId in catalog entry");

  const constraint = offer["odrl:permission"]?.["odrl:constraint"];

  const builtOffer = {
    "@context": "http://www.w3.org/ns/odrl.jsonld",
    "@type": "odrl:Offer",
    "@id": offerId,
    "assigner": jsonData["dspace:participantId"],
    "odrl:permission": {
      "odrl:target": assetId,
      "odrl:action": { "odrl:type": "http://www.w3.org/ns/odrl/2/use" },
      "odrl:constraint": constraint
    },
    "odrl:prohibition": [],
    "odrl:obligation": [],
    "odrl:target": { "@id": assetId }
  };

  bru.setVar("SUBMODEL_CATALOG_OFFER", JSON.stringify(builtOffer));
  bru.setVar("SUBMODEL_CATALOG_OFFER_ID", offerId);
}

tests {
  test("Status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
}

meta {
  name: Send Notification
  type: http
  seq: 5
}

post {
  url: {{SUPPLIER_PURIS_BACKEND}}/catena/demand-and-capacity-notification
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  X-Api-Key: {{SUPPLIER_PURIS_BACKEND_API_KEY}}
}

body:json {
  {
    "notificationId": "be63823a-39ae-4f4d-9962-6941376267c3",
    "partnerBpnl": "{{CUSTOMER_BPNL}}",
    "sourceDisruptionId": "c9274399-cd3a-48c1-923c-c9b4eec2aa7b",
    "text": "Capacity reduction due to ongoing strike.",
    "effect": "capacity-reduction",
    "leadingRootCause": "strike",
    "status": "open",
    "contentChangedAt": "2023-12-13T15:00:00+01:00",
    "startDateOfEffect": "2023-12-13T15:00:00+01:00",
    "expectedEndDateOfEffect": "2025-12-17T08:00:00+01:00",
    "affectedSitesBpnsSender": [],
    "affectedSitesBpnsRecipient": [],
    "affectedMaterialNumbers": [],
    "relatedNotificationIds": []
  }
}

tests {
  test("response is ok", function() {
      expect(res.getStatus()).to.equal(201);
  })
}

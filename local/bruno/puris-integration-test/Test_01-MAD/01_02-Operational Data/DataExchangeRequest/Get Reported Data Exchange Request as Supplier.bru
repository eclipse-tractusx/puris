meta {
  name: Get Reported Data Exchange Request as Supplier
  type: http
  seq: 2
}

get {
  url: {{SUPPLIER_PURIS_BACKEND}}/catena/data-exchange-request/reported
  body: none
  auth: none
}

headers {
  X-Api-Key: {{SUPPLIER_PURIS_BACKEND_API_KEY}}
}

script:pre-request {
  console.log("Waiting 5 seconds");
  await (new Promise(resolve => setTimeout(resolve, 5000)));
}

tests {
  test("response is ok", function() {
      expect(res.getStatus()).to.equal(200);
  })

  test("Verify response contains one reported data exchange request object", function () {
      expect(res.getBody()).to.be.an("array").with.lengthOf(1);
  });

  const firstUuid = res.getBody()[0].uuid;
  bru.setVar("reportedRequestUuid", firstUuid);
  
}

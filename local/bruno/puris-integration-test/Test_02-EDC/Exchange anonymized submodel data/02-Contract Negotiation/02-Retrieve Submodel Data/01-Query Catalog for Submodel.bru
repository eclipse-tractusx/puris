meta {
  name: 01-Query Catalog for Submodel
  type: http
  seq: 1
  tags: [
    exchange-anonymized-data
  ]
}

post {
  url: {{CUSTOMER_EDC}}/{{MANAGEMENT_PATH}}/v3/catalog/request
  body: json
  auth: apikey
}

auth:apikey {
  key: X-API-KEY
  value: {{CUSTOMER_EDC_API_KEY}}
  placement: header
}

body:json {
  {
    "@context": {
      "@vocab": "https://w3id.org/edc/v0.0.1/ns/"
    },
    "@type": "CatalogRequest",
    "protocol": "dataspace-protocol-http",
    "counterPartyAddress": "{{SUPPLIER_EDC_EXT_HOSTNAME}}/{{PROTOCOL_PATH}}",
    "counterPartyId": "{{SUPPLIER_BPNL}}",
    "querySpec": {
      "offset": 0,
      "limit": 100,
      "filter": "",
      "range": {
        "from": 0,
        "to": 100
      },
      "filterExpression": [
        {
          "@type": "CriterionDto",
          "operandLeft": "https://w3id.org/catenax/ontology/common#version",
          "operator": "=",
          "operandRight": "3.0"
        },
        {
          "@type": "CriterionDto",
          "operandLeft": "'http://purl.org/dc/terms/type'.'@id'",
          "operator": "=",
          "operandRight": "https://w3id.org/catenax/taxonomy#Submodel"
        }
      ]
    }
  }
}

script:pre-request {
  const rawSubmodelData = bru.getVar("SUBMODEL_DATA")
  const rawSubmodelIndex = bru.getVar("CURRENT_SUBMODEL_INDEX")

  if (rawSubmodelData == null)
  {
    throw new Error("SUBMODEL_DATA not set!")
  }
  if (rawSubmodelIndex == null)
  {
    throw new Error("CURRENT_SUBMODEL_INDEX not set!")
  }

  const submodelData = JSON.parse(rawSubmodelData)
  const submodelIndex = Number(rawSubmodelIndex)

  if (submodelIndex < 0 || submodelIndex >= submodelData.length)
  {
    throw new Error("CURRENT_SUBMODEL_INDEX out of bounds!")
  }

  const currentSubmodelData = submodelData[submodelIndex]
  
  bru.setVar("SUBMODEL_SEMANTIC_ID", currentSubmodelData.semanticId)
  bru.setVar("SUBMODEL_ENDPOINT", currentSubmodelData.submodelEndpoint)
  bru.setVar("SUBMODEL_DSP_ENDPOINT", currentSubmodelData.dspEndpoint)
  bru.setVar("SUBMODEL_ASSET", currentSubmodelData.asset)

  const align = (text) => text.padEnd(20, " ")

  console.log("---------------------------------------------------------------------------------------------------------------------")
  console.log(`Testing submodel data transfer ${submodelIndex + 1}/${submodelData.length}`)
  console.log(`${align("Submodel name:")} ${currentSubmodelData.name}`)
  console.log(`${align("Semantic id:")} ${currentSubmodelData.semanticId}`)
  console.log(`${align("Submodel endpoint:")} ${currentSubmodelData.submodelEndpoint}`)
  console.log("---------------------------------------------------------------------------------------------------------------------")
}

script:post-response { 
  let jsonData = res.getBody()
  let catalog = jsonData['dcat:dataset']
  
  if (!catalog || catalog.length === 0) {
    throw new Error("Catalog response contains no datasets!")
  }

  const submodelSemanticId = bru.getVar("SUBMODEL_SEMANTIC_ID")
  const catalogEntry = catalog.find(ce => ce["https://admin-shell.io/aas/3/0/HasSemantics/semanticId"]["@id"] === submodelSemanticId)

  if (!catalogEntry) {
    throw new Error(`No catalog entry found for semanticId: ${submodelSemanticId}`)
  }
  
  let offer = catalogEntry["odrl:hasPolicy"]
  const offerId = offer["@id"]
  const assetId = catalogEntry.id
  
  offer.offerId = offerId
  delete offer["@id"]
  
  offer.assetId = assetId
  
  offer = {
      "@context": "http://www.w3.org/ns/odrl.jsonld",
      "@type": "odrl:Offer",
      "@id": offerId,
      "assigner": jsonData["dspace:participantId"],
      "odrl:permission": {
          "odrl:target": assetId,
          "odrl:action": {
              "odrl:type": "http://www.w3.org/ns/odrl/2/use"
          },
          "odrl:constraint": offer["odrl:permission"]["odrl:constraint"]
      },
      "odrl:prohibition": [],
      "odrl:obligation": [],
      "odrl:target": {
          "@id": assetId
      }
  }
  bru.setVar("SUBMODEL_CATALOG_OFFER", JSON.stringify(offer))
  bru.setVar("SUBMODEL_CATALOG_OFFER_ID", offerId)
}

tests {
  test("Status code is 200", function () {
      expect(res.getStatus()).to.equal(200);
  });
}
